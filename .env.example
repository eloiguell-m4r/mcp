# --- Motion4Rent MCP server ---

# Transport: "http" (remot, per a connector de Claude / app de ChatGPT) o "stdio" (dev local).
MCP_TRANSPORT=http

# Port del servidor HTTP (mode http).
PORT=8787

# Token bearer opcional per protegir l'endpoint /mcp (mode http). Buit = sense auth.
# Els clients han d'enviar: Authorization: Bearer <token>
MCP_AUTH_TOKEN=

# Base URL de l'API de motion4rent (motion4rent-api). Els endpoints /search/results,
# /ai/cities i /details són públics. Ex. local: http://localhost:3000
M4R_API_BASE_URL=http://localhost:3000

# Base URL de la web pública (per construir els deep-links de reserva).
WEB_BASE_URL=https://www.motion4rent.com

# Tenant (de moment només motion4rent).
TENANT=motion4rent

# --- Booking headless (Fase 3A, opcional) ---
# Base URL del WEB PHP que exposa POST /ai/checkout (crea el hold + Stripe).
# Buit = la tool create_booking queda deshabilitada (només descoberta + deep-link).
# Ex.: https://www.motion4rent.com  (o localhost si el MCP i el web són co-ubicats).
M4R_CHECKOUT_BASE_URL=

# Secret compartit amb el web (ha de coincidir amb AI_CHECKOUT_SECRET del web).
# S'envia com a Authorization: Bearer <secret> a /ai/checkout.
M4R_CHECKOUT_SECRET=
