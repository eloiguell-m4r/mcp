{
  "name": "motion4rent-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Servidor MCP de Motion4Rent: descoberta de lloguer de mobilitat (cerca + info) i deep-link a la web per reservar/pagar. Read-only; NO crea comandes ni cobra.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "motion4rent-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:stdio": "MCP_TRANSPORT=stdio tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.0",
    "jose": "^6.2.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
